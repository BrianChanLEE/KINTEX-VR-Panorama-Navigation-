<STYLE TYPE="text/css">

body{padding:0;margin:0;text-align:center;}

body, div, td{color:#444;font:12px "굴림",Gulim,AppleGothic,sans-serif;}



</style>

<script language="javascript">

	function setCookie( name, value, expiredays) { //tolips_kysong
		var todayDate = new Date();
		todayDate.setDate( todayDate.getDate() + expiredays );
		document.cookie = name + "=" + escape( value ) + "; path=/; expires=" + todayDate.toGMTString() + ";"
	}
		
			
	 
	function closeWindow() { //tolips_kysong	
		setCookie("sorry_pop", "no" , 1);
		self.close();		
	}

</script>

</head>

<body>

<table width="400" height="400"><tr><td align="center" valign="middle">

